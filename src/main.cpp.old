#include "Config/config.h"
#include "USB.h"
#include "USBCDC.h"
#include <Arduino.h>
#include <ButtonCtrl.h>
// #include <Control_Surface.h>

USBCDC SerialUSB;
ButtonCtrl buttons[NUM_BUTTONS];
// USBDebugMIDI_Interface midi {115200};

void setup() {
  USB.begin();
  SerialUSB.begin(115200);
  // midi.begin();

  pinMode(LED_BUILTIN, OUTPUT);

  for (int i = 0; i < NUM_BUTTONS; i++) {
    buttons[i].begin(buttonPins[i]);
  }

  delay(2000);
}

void loop() {
  for (int i = 0; i < NUM_BUTTONS; i++) {
    buttons[i].update();

    if (buttons[i].wasPressed()) {
      SerialUSB.println("Button " + String(i) + " was pressed!");
      digitalWrite(LED_BUILTIN, HIGH);
      // midi.sendNoteOn(60, 127);
    } else if (buttons[i].wasReleased()) {
      SerialUSB.println("Button " + String(i) + " was released!");
      digitalWrite(LED_BUILTIN, LOW);
      // midi.sendNoteOff(60, 0);
    }
  }
}
